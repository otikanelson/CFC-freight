{
  "version": 2,
  "name": "freight-backend", 
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node@3.0.7",
      "config": {
        "maxDuration": 30,
        "includeFiles": ["package.json"]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/auth/(.*)",
      "dest": "api/index.ts"
    },
    {
      "src": "/health",
      "dest": "api/index.ts"
    },
    {
      "src": "/api",
      "dest": "api/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.ts"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "regions": ["iad1"],
  "installCommand": "npm install --production"
}