{
  "version": 2,
  "builds": [
    {
      "src": "index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "hello.ts", 
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/auth/(.*)",
      "dest": "index.ts"
    },
    {
      "src": "/health",
      "dest": "index.ts"
    },
    {
      "src": "/api/hello",
      "dest": "hello.ts"
    },
    {
      "src": "/api",
      "dest": "index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "index.ts"
    }
  ]
}